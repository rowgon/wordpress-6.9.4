            {
              "id": "tt_rd_home_solutions_list",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<div class=\"tt-rd-solution-list\"><div class=\"tt-rd-solution-item\"><div class=\"tt-rd-solution-number\">01</div><div class=\"tt-rd-solution-copy\"><h3>Pergolas Bioclimaticas</h3><p>Elegancia y control climatico total para tu porche o terraza.</p></div></div><div class=\"tt-rd-solution-item\"><div class=\"tt-rd-solution-number\">02</div><div class=\"tt-rd-solution-copy\"><h3>Cerramientos de Terrazas</h3><p>Disenos modernos que integran tu terraza con el interior del hogar.</p></div></div><div class=\"tt-rd-solution-item\"><div class=\"tt-rd-solution-number\">03</div><div class=\"tt-rd-solution-copy\"><h3>Cortinas de Cristal</h3><p>Vistas panoramicas sin perfiles verticales. Transparencia total.</p></div></div><div class=\"tt-rd-solution-item\"><div class=\"tt-rd-solution-number\">04</div><div class=\"tt-rd-solution-copy\"><h3>Carpinteria de Aluminio</h3><p>Puertas, ventanas y estructuras metalicas a medida.</p></div></div><div class=\"tt-rd-solution-item\"><div class=\"tt-rd-solution-number\">05</div><div class=\"tt-rd-solution-copy\"><h3>Vallas y Cercados</h3><p>Seguridad y privacidad con disenos contemporaneos para tu parcela.</p></div></div></div>",
